// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       String @id @default(cuid())
  name                     String @unique
  username                 String? @unique
  email                    String? @unique
  phone                    String? @unique
  passwordHash             String?
  securityAnswers          String?
  passwordResetTokenHash   String?
  passwordResetTokenExpiresAt DateTime?
  role                     String @default("user")
  approved                 Boolean @default(false)
  expenses Expense[]
  monthlyPayments MonthlyPayment[]
  activities Activity[]
  menus Menu[]
  inventoryItems InventoryItem[]
  notifications Notification[] @relation("NotificationCreator")
  menuSuggestions MenuSuggestion[]
  availabilities Availability[]
  supplyReports SupplyReport[] @relation("SupplyReportCreator")
}

model RegistrationVerification {
  id              String   @id @default(cuid())
  name            String
  username        String   @unique
  email           String   @unique
  phone           String?   @unique
  passwordHash    String
  securityAnswers String
  otpHash         String
  otpExpiresAt    DateTime
  createdAt       DateTime @default(now())
}

model Expense {
  id          String   @id @default(cuid())
  date        String
  type        String
  category    String
  amount      Float
  description String
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
}

model MonthlyPayment {
  id          String   @id @default(cuid())
  month       String
  paid        Boolean
  amount      Float
  memberName  String?
  paymentType String?  @default("custom")
  note        String?
  reminderSent Boolean @default(false)
  expenseId   String?  @unique
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
}

model Menu {
  id          String       @id @default(cuid())
  week        String
  items       MenuItem[]
  purchasers  String[]
  userId      String
  user        User         @relation(fields: [userId], references: [id])
  createdAt   DateTime     @default(now())
}

model MenuItem {
  id        String @id @default(cuid())
  day       String
  lunch     String
  dinner    String
  lunchCooks String[]
  dinnerCooks String[]
  menuId    String
  menu      Menu  @relation(fields: [menuId], references: [id])
}

model Activity {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  timestamp DateTime @default(now())
}

model InventoryItem {
  id              String   @id @default(cuid())
  name            String
  category        String
  quantity        Float
  unit            String
  lowStockThreshold Float @default(0)
  lastPurchasedAt String?
  lastPrice       Float?
  note            String?
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  createdAt       DateTime @default(now())
}

model Notification {
  id          String   @id @default(cuid())
  title       String
  message     String
  category    String   @default("general")
  createdById String
  recipientUserIds String[] @default([])
  readByUserIds String[] @default([])
  createdBy   User     @relation("NotificationCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
}

model MenuSuggestion {
  id            String   @id @default(cuid())
  suggestion    String
  preferredDay  String?
  preferredMeal String?
  status        String   @default("pending")
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  createdAt     DateTime @default(now())
}

model Availability {
  id        String   @id @default(cuid())
  week      String
  day       String
  meal      String
  available Boolean  @default(true)
  note      String?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model SupplyReport {
  id          String   @id @default(cuid())
  title       String
  category    String
  itemName    String?
  message     String
  status      String   @default("missing")
  response    String?
  createdById String
  createdBy   User     @relation("SupplyReportCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
